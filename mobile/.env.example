# =============================================
# ROSports.app — Variables de entorno
# Copiar a .env y completar con valores reales
# NUNCA commitear el archivo .env
# =============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Firebase
FIREBASE_PROJECT_ID=rosports-app

# Pagos — PayU (sandbox)
PAYU_API_KEY=your-payu-api-key
PAYU_MERCHANT_ID=your-merchant-id
PAYU_ACCOUNT_ID=your-account-id
PAYU_ENV=sandbox   # sandbox | production

# Email — Resend
RESEND_API_KEY=your-resend-api-key

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
